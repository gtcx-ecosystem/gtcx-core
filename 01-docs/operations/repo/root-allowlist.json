{
  "$schema": "https://gtcx.org/schemas/audit/root-allowlist.schema.json",
  "version": "2.0.0",
  "schema_version": "1.0.0",
  "updated": "2026-06-05",
  "description": "Repo-specific root allowlist for gtcx-core (five-hub layout). Source of truth for CI root-cleanliness checks.",

  "required_files": ["README.md", "AGENTS.md"],

  "allowed_files": [
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "package.json",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml",
    "turbo.json",
    "tsconfig.json",
    "eslint.config.js",
    "commitlint.config.js",
    "baseline.config.ts",
    "hygiene.config.json",
    ".gitignore",
    ".gitattributes",
    ".dockerignore",
    ".editorconfig",
    ".prettierrc",
    ".prettierignore",
    ".env.example"
  ],

  "allowed_directories": [
    "00-archive",
    "01-docs",
    "02-ops",
    "03-platform",
    "04-ship",
    "05-audit",
    "config",
    "rust"
  ],

  "allowed_dot_directories": [
    ".github",
    ".husky",
    ".agent",
    ".baseline",
    ".cursor",
    ".changeset",
    ".claude",
    ".gemini",
    ".kimi"
  ],

  "ignored_prefixes": [".", "node_modules"],

  "ignored_exact": ["node_modules"],

  "deprecated_files": {},

  "forbidden_root_names": {
    "audit": "Move to 01-docs/05-audit/. The gitignored audit/ is a developer-local scratch dir and must never be tracked.",
    "coverage": "Build artifact — gitignored. Never commit.",
    "session-notes": "Use 01-docs/session-notes/.",
    "_archive": "Gitignored historical tree; must not be committed at root.",
    "Dockerfile": "Use 04-ship/docker/Dockerfile.",
    "typedoc.json": "Use config/toolchain/typedoc.json.",
    "vitest.workspace.ts": "Use config/toolchain/vitest.workspace.ts.",
    "baseline.config.json": "Use baseline.config.ts (RAG) only."
  },

  "forbidden_name_prefixes": ["IMG_", "Screenshot", "Untitled"],

  "human_owned_paths": {
    "_delete": {
      "owner": "repository maintainer (manual)",
      "agent_action": "none — do not delete, move, empty, or schedule in sprints/PRs",
      "ci_enforcement": "excluded from root-cleanliness check",
      "audit_reporting": "may note as out-of-scope; never score as P0/P1",
      "rationale": "Maintainer-managed terminal cleanup."
    }
  },

  "relocate_hints": {
    "audits": "01-docs/05-audit/",
    "session_analysis": "01-docs/session-notes/",
    "local_scratch": ".local/",
    "repo_policy": "01-docs/operations/repo/",
    "ship_docker": "04-ship/docker/",
    "toolchain": "config/toolchain/",
    "rust_workspace": "rust/"
  }
}
