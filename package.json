{
  "name": "gtcx-core",
  "version": "0.1.0",
  "private": true,
  "description": "GTCX Core - Shared foundation packages, cryptographic primitives, and type definitions",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtcx-ecosystem/gtcx-core.git"
  },
  "author": "GTCX Protocol",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage:critical": "pnpm --filter @gtcx/crypto test:coverage && pnpm --filter @gtcx/domain test:coverage && pnpm --filter @gtcx/security test:coverage && pnpm --filter @gtcx/services test:coverage && pnpm --filter @gtcx/verification test:coverage",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "check:dist": "test -z \"$(git ls-files 'packages/*/dist/*')\"",
    "architecture:check": "node ./tools/check-package-boundaries.mjs",
    "check:native": "ts-node packages/crypto-native/src/preflight.ts",
    "quality:governance:check": "node ./tools/check-governance.mjs",
    "quality:verify-branch-protection": "./tools/verify-branch-protection.sh",
    "quality:kpi:collect": "node ./tools/collect-kpi-history.mjs",
    "quality:kpi:export": "node ./tools/export-quality-kpis.mjs",
    "security:threat-matrix": "node ./tools/check-threat-matrix.mjs",
    "security:secret-scan": "node ./tools/check-secrets.mjs",
    "security:crypto-deps": "node ./tools/check-crypto-deps.mjs",
    "ops:check": "node ./tools/check-ops-prereqs.mjs",
    "ops:check:json": "node ./tools/check-ops-prereqs.mjs --json",
    "ops:emit-doc": "node ./tools/check-ops-prereqs.mjs --emit-doc",
    "build:reproducible": "node ./tools/check-reproducible-build.mjs",
    "perf:capture-latest": "node ./tools/capture-benchmark-results.mjs",
    "perf:update-history": "node ./tools/update-benchmark-history.mjs",
    "perf:check-budgets": "node ./tools/check-performance-budgets.mjs",
    "api:check": "node ./tools/check-api-surface.mjs",
    "api:check:release": "API_ENFORCE_SEMVER=true API_BASELINE_REF=HEAD~1 node ./tools/check-api-surface.mjs",
    "api:update-baseline": "node ./tools/check-api-surface.mjs --update",
    "provenance:generate": "node ./tools/generate-provenance-manifest.mjs",
    "release:ga:evidence:summary": "node ./tools/generate-ga-evidence-summary.mjs",
    "release:ga:evidence:check": "node ./tools/generate-ga-evidence-summary.mjs --check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish --provenance",
    "docs": "typedoc",
    "docs:check-links": "node ./tools/check-markdown-links.mjs",
    "docs:rust": "cd rust && cargo doc --workspace --no-deps",
    "bench": "cd rust && cargo bench --workspace",
    "network:mesh:demo": "node ./tools/network-mesh-demo.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@multiformats/multiaddr": "^12.5.1",
    "@types/node": "^22.10.0",
    "eslint": "^10.0.0",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^6.0.0",
    "vite": "8.0.10",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "@multiformats/multiaddr": "12.5.1",
      "@noble/curves@1": "1.9.0",
      "@noble/hashes@1": "1.8.0",
      "minimatch": ">=9.0.6",
      "yaml": ">=2.8.3",
      "rollup": ">=4.59.0",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "esbuild": ">=0.25.0",
      "vite": "8.0.10",
      "postcss": ">=8.5.10",
      "fast-uri": ">=3.1.2"
    }
  },
  "gtcx": {
    "principles": [
      "P1",
      "P2",
      "P4",
      "P11"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
