{
  "name": "gtcx-core",
  "version": "0.1.0",
  "private": true,
  "description": "GTCX Core - Shared foundation packages, cryptographic primitives, and type definitions",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtcx-ecosystem/gtcx-core.git"
  },
  "author": "GTCX Protocol",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage:critical": "pnpm --filter @gtcx/crypto test:coverage && pnpm --filter @gtcx/domain test:coverage && pnpm --filter @gtcx/security test:coverage && pnpm --filter @gtcx/services test:coverage && pnpm --filter @gtcx/verification test:coverage",
    "lint": "turbo run lint --concurrency=1",
    "clean": "turbo run clean && rm -rf node_modules",
    "check:dist": "test -z \"$(git ls-files '03-platform/packages/*/dist/*')\"",
    "architecture:check": "node ./03-platform/tools/check-package-boundaries.mjs",
    "check:native": "ts-node 03-platform/packages/crypto-native/03-platform/src/preflight.ts",
    "quality:governance:check": "node ./03-platform/tools/check-governance.mjs",
    "quality:verify-branch-protection": "./03-platform/tools/verify-branch-protection.sh",
    "quality:kpi:collect": "node ./03-platform/tools/collect-kpi-history.mjs",
    "quality:kpi:export": "node ./03-platform/tools/export-quality-kpis.mjs",
    "security:threat-matrix": "node ./03-platform/tools/check-threat-matrix.mjs",
    "security:secret-scan": "node ./03-platform/tools/check-secrets.mjs",
    "security:crypto-deps": "node ./03-platform/tools/check-crypto-deps.mjs",
    "ops:check": "node ./03-platform/tools/check-ops-prereqs.mjs",
    "ci:confirmation": "node ./03-platform/tools/run-ci-confirmation.mjs",
    "ops:check:json": "node ./03-platform/tools/check-ops-prereqs.mjs --json",
    "ops:emit-doc": "node ./03-platform/tools/check-ops-prereqs.mjs --emit-doc",
    "ai:evaluate": "tsx 03-platform/packages/ai-eval/03-platform/src/cli.ts",
    "build:reproducible": "node ./03-platform/tools/check-reproducible-build.mjs",
    "bundle:check-budgets": "node ./03-platform/tools/check-bundle-budgets.mjs",
    "perf:capture-latest": "node ./03-platform/tools/capture-benchmark-results.mjs",
    "perf:update-history": "node ./03-platform/tools/update-benchmark-history.mjs",
    "perf:check-budgets": "node ./03-platform/tools/check-performance-budgets.mjs",
    "perf:zkp-profile-load": "node ./03-platform/tools/bench/zkp-profile-load-test.mjs",
    "jurisdiction:validate-packs": "pnpm --filter @gtcx/jurisdiction-config validate:packs",
    "certified-pack:build-manifest": "node 03-platform/tools/certified-pack/build-manifest.mjs",
    "certified-pack:verify-manifest": "node 03-platform/tools/certified-pack/verify-manifest.mjs",
    "vendor-evidence:build-manifest": "node 03-platform/tools/vendor-evidence/build-manifest.mjs",
    "vendor-evidence:verify-manifest": "node 03-platform/tools/vendor-evidence/verify-manifest.mjs",
    "api:check": "node ./03-platform/tools/check-api-surface.mjs",
    "api:check:release": "API_ENFORCE_SEMVER=true API_BASELINE_REF=HEAD~1 node ./03-platform/tools/check-api-surface.mjs",
    "api:update-baseline": "node ./03-platform/tools/check-api-surface.mjs --update",
    "provenance:generate": "node ./03-platform/tools/generate-provenance-manifest.mjs",
    "provenance:check-npm": "node ./03-platform/tools/check-npm-provenance.mjs",
    "provenance:check-npm:strict": "node ./03-platform/tools/check-npm-provenance.mjs --strict",
    "test:tools": "node --test 03-platform/tools/*.test.mjs",
    "release:ga:evidence:summary": "node ./03-platform/tools/generate-ga-evidence-summary.mjs",
    "release:ga:evidence:check": "node ./03-platform/tools/generate-ga-evidence-summary.mjs --check && node ./03-platform/tools/check-ai-scorecard.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm version-packages && pnpm install && pnpm build && node ./03-platform/tools/publish-packages-provenance.mjs",
    "release:publish:provenance": "node ./03-platform/tools/publish-packages-provenance.mjs",
    "docs": "typedoc",
    "docs:check-links": "node ./03-platform/tools/check-markdown-links.mjs",
    "docs:check-frontmatter": "node ./03-platform/tools/check-doc-frontmatter.mjs",
    "docs:rust": "cd rust && cargo doc --workspace --no-deps",
    "bench": "cd rust && cargo bench --workspace",
    "network:mesh:demo": "node ./03-platform/tools/network-mesh-demo.mjs",
    "prepare": "husky",
    "agent:sync": "node 03-platform/scripts/agent-sync/sync.mjs",
    "agent:check": "node 03-platform/scripts/agent-sync/sync.mjs --check",
    "agent:start": "node 03-platform/scripts/agent-session-start.mjs",
    "agent:session-start": "pnpm run agent:start",
    "agent:environment:check": "node ../baseline-os/scripts/ecosystem/lib/agent-environment-autonomy.mjs --repo-path=.",
    "agent:capabilities:check": "node ../baseline-os/scripts/ecosystem/lib/agent-capability-manifest.mjs --repo-path=.",
    "agent:cli:path": "node 03-platform/scripts/agent-cli-path.mjs",
    "agent:next-work": "node 03-platform/scripts/agent-next-work.mjs",
    "agent:bout": "node 03-platform/scripts/agent-execution-bout.mjs",
    "agent:bout:check": "node 03-platform/scripts/check-agent-execution-bout.mjs",
    "agent:reconcile-launch": "node 03-platform/scripts/reconcile-launch-state.mjs",
    "agent:reconcile-auto-dev": "node 03-platform/scripts/reconcile-auto-dev-data.mjs",
    "agent:launch:check": "node 03-platform/scripts/check-agent-launch-focus.mjs",
    "agent:work-selection:check": "node 03-platform/scripts/check-agent-work-selection.mjs",
    "agent:protocols:check": "node ./03-platform/tools/check-agent-protocols.mjs",
    "agent:universal:check": "node ../gtcx-agentic/03-platform/scripts/check-universal-agent-enforcement.mjs --repo-only",
    "agent:attestation:check": "node ./03-platform/tools/check-agent-attestation.mjs",
    "agent:hub-drift:check": "node ./03-platform/tools/check-hub-protocol-drift.mjs",
    "agent:hub-snapshot:update": "node ./03-platform/tools/check-hub-protocol-drift.mjs --update",
    "agent:foundation-protocols:check": "node ./03-platform/tools/check-foundation-protocols.mjs",
    "readiness:lanes:check": "node ./03-platform/tools/check-readiness-lanes.mjs",
    "test:kat-cross-impl": "cargo run --manifest-path rust/gtcx-zkp/Cargo.toml --bin kat-cross-impl-verify -- --all",
    "agent:coordination:check": "node 03-platform/scripts/check-coordination-hygiene.mjs",
    "agent:cross-repo-deps:check": "node 03-platform/scripts/check-cross-repo-dependencies.mjs",
    "agent:git-push": "node 03-platform/scripts/agent-git-push.mjs",
    "kimi:skills:sync": "node 03-platform/scripts/sync-kimi-project-skills.mjs",
    "kimi:skills:check": "node 03-platform/scripts/check-kimi-project-skills.mjs",
    "ops:trusted-setup:verify-publish": "node 03-platform/scripts/ops/verify-trusted-setup-publish.mjs",
    "agent:bout-progress": "node 03-platform/scripts/agent-bout-progress.mjs",
    "agent:bout-progress:check": "node 03-platform/scripts/check-agent-bout-progress.mjs",
    "agent:reconcile-bout-progress": "node 03-platform/scripts/reconcile-bout-progress.mjs",
    "check:workspace-root-cleanliness": "python3 03-platform/scripts/ops/check-workspace-root-cleanliness.py",
    "check:workspace-root-cleanliness:strict": "python3 03-platform/scripts/ops/check-workspace-root-cleanliness.py --strict",
    "session": "node ../baseline-os/packages/baselineos/dist/cli/bin.js session",
    "next": "node ../baseline-os/scripts/ecosystem/work-next.mjs",
    "gates": "node ../baseline-os/scripts/ecosystem/human-gates-check.mjs",
    "hub": "node ../baseline-os/scripts/ecosystem/hub-sync.mjs",
    "workspace:check": "node 03-platform/scripts/workspace/check.mjs",
    "pm:sync": "node 03-platform/scripts/workspace/pm-sync.mjs",
    "pm:status": "node 03-platform/scripts/workspace/pm-status.mjs"
  },
  "devDependencies": {
    "@gtcx/eslint-config": "workspace:*",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@multiformats/multiaddr": "^12.5.1",
    "@types/node": "^22.10.0",
    "eslint": "^10.4.1",
    "fast-check": "^4.8.0",
    "glob": "^11",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@multiformats/multiaddr": "12.5.1",
      "@noble/curves@1": "1.9.0",
      "@noble/hashes@1": "1.8.0",
      "minimatch": ">=9.0.6",
      "yaml": ">=2.8.3",
      "rollup": ">=4.59.0",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "esbuild": ">=0.25.0",
      "vite": "8.0.16",
      "postcss": ">=8.5.10",
      "fast-uri": ">=3.1.2",
      "brace-expansion": ">=5.0.6"
    }
  },
  "gtcx": {
    "principles": [
      "P1",
      "P2",
      "P4",
      "P11"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
