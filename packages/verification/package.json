{
  "name": "@gtcx/verification",
  "version": "2.0.0",
  "description": "Certificate generation, QR codes, and verification proofs for GTCX Protocol",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./certificates": {
      "types": "./dist/certificates/index.d.ts",
      "import": "./dist/certificates/index.mjs",
      "require": "./dist/certificates/index.js"
    },
    "./qr": {
      "types": "./dist/qr/index.d.ts",
      "import": "./dist/qr/index.mjs",
      "require": "./dist/qr/index.js"
    },
    "./proofs": {
      "types": "./dist/proofs/index.d.ts",
      "import": "./dist/proofs/index.mjs",
      "require": "./dist/proofs/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gtcx/crypto": "workspace:*",
    "@gtcx/types": "workspace:*",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@gtcx/tsup-config": "workspace:*",
    "@gtcx/typescript-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@gtcx/ai": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@gtcx/ai": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtcx-ecosystem/gtcx-core.git",
    "directory": "packages/verification"
  },
  "license": "MIT",
  "homepage": "https://github.com/gtcx-ecosystem/gtcx-core/tree/main/packages/verification#readme",
  "bugs": {
    "url": "https://github.com/gtcx-ecosystem/gtcx-core/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false
}
