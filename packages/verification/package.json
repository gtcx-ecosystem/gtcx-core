{
  "name": "@gtcx/verification",
  "version": "0.1.0",
  "description": "Certificate generation, QR codes, and verification proofs for GTCX Protocol",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./certificates": {
      "types": "./dist/certificates/index.d.ts",
      "import": "./dist/certificates/index.mjs",
      "require": "./dist/certificates/index.js"
    },
    "./qr": {
      "types": "./dist/qr/index.d.ts",
      "import": "./dist/qr/index.mjs",
      "require": "./dist/qr/index.js"
    },
    "./proofs": {
      "types": "./dist/proofs/index.d.ts",
      "import": "./dist/proofs/index.mjs",
      "require": "./dist/proofs/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@gtcx/ai": "workspace:*",
    "@gtcx/crypto": "workspace:*",
    "@gtcx/types": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@gtcx/typescript-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@noble/hashes": "^1.3.0",
    "@noble/curves": "^1.3.0"
  }
}
