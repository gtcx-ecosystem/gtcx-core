{
  "name": "@gtcx/verification",
  "version": "0.1.0",
  "description": "Certificate generation, QR codes, and verification proofs for GTCX Protocol",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./certificates": "./src/certificates/index.ts",
    "./qr": "./src/qr/index.ts",
    "./proofs": "./src/proofs/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@gtcx/crypto": "workspace:*",
    "@gtcx/types": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@gtcx/typescript-config": "workspace:*",
    "typescript": "^5.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@noble/hashes": "^1.3.0",
    "@noble/curves": "^1.3.0"
  }
}
