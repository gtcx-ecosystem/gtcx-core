{
  "name": "@gtcx/runtime",
  "version": "0.1.0",
  "description": "Batteries-included runtime substrate: api-client, connectivity, resilience, telemetry",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gtcx/api-client": "workspace:*",
    "@gtcx/connectivity": "workspace:*",
    "@gtcx/logging": "workspace:*",
    "@gtcx/resilience": "workspace:*",
    "@gtcx/telemetry": "workspace:*"
  },
  "devDependencies": {
    "@gtcx/tsup-config": "workspace:*",
    "@gtcx/typescript-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtcx-ecosystem/gtcx-core.git",
    "directory": "packages/runtime"
  },
  "license": "MIT",
  "sideEffects": false
}
