    "lint": "eslint src/"
  },
  "dependencies": {
    "@gtcx/domain": "workspace:*"
  },
  "devDependencies": {
    "@gtcx/tsup-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtcx-ecosystem/gtcx-core.git",
    "directory": "packages/events"
  },
  "license": "MIT",
  "homepage": "https://github.com/gtcx-ecosystem/gtcx-core/tree/main/packages/events#readme",
  "bugs": {
    "url": "https://github.com/gtcx-ecosystem/gtcx-core/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false
