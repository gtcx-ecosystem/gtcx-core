{
  "name": "@gtcx/services",
  "version": "0.1.0",
  "private": true,
  "description": "Application-level business services for GTCX Protocol — registration, trading, compliance",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./registration": {
      "types": "./dist/registration.d.ts",
      "import": "./dist/registration.mjs",
      "require": "./dist/registration.js"
    },
    "./trading": {
      "types": "./dist/trading.d.ts",
      "import": "./dist/trading.mjs",
      "require": "./dist/trading.js"
    },
    "./compliance": {
      "types": "./dist/compliance.d.ts",
      "import": "./dist/compliance.mjs",
      "require": "./dist/compliance.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@gtcx/domain": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@gtcx/typescript-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  },
  "keywords": [
    "gtcx",
    "services",
    "registration",
    "trading",
    "compliance"
  ],
  "author": "GTCX Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtcx/gtcx.git",
    "directory": "packages/services"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
