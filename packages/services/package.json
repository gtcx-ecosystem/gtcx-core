{
  "name": "@gtcx/services",
  "version": "1.0.1",
  "description": "Application-level business services for GTCX Protocol — registration, trading, compliance",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./registration": {
      "types": "./dist/registration.d.ts",
      "import": "./dist/registration.mjs",
      "require": "./dist/registration.js"
    },
    "./trading": {
      "types": "./dist/trading.d.ts",
      "import": "./dist/trading.mjs",
      "require": "./dist/trading.js"
    },
    "./compliance": {
      "types": "./dist/compliance.d.ts",
      "import": "./dist/compliance.mjs",
      "require": "./dist/compliance.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gtcx/crypto": "workspace:*",
    "@gtcx/domain": "workspace:*",
    "@gtcx/events": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@gtcx/tsup-config": "workspace:*",
    "@gtcx/typescript-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  },
  "keywords": [
    "gtcx",
    "services",
    "registration",
    "trading",
    "compliance"
  ],
  "author": "GTCX Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtcx-ecosystem/gtcx-core.git",
    "directory": "packages/services"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/gtcx-ecosystem/gtcx-core/tree/main/packages/services#readme",
  "bugs": {
    "url": "https://github.com/gtcx-ecosystem/gtcx-core/issues"
  },
  "sideEffects": false
}
