{
  "name": "@gtcx/security",
  "version": "1.0.0",
  "description": "Security utilities for GTCX Protocol - validation, auth, offline security, audit logging",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "require": "./dist/validation/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./offline": {
      "types": "./dist/offline/index.d.ts",
      "import": "./dist/offline/index.js",
      "require": "./dist/offline/index.cjs"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "import": "./dist/audit/index.js",
      "require": "./dist/audit/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@gtcx/crypto": "workspace:*",
    "@gtcx/types": "workspace:*"
  },
  "devDependencies": {
    "@gtcx/typescript-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "gtcx",
    "security",
    "validation",
    "authentication",
    "offline",
    "audit"
  ],
  "author": "GTCX Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtcx-ecosystem/gtcx-core.git",
    "directory": "packages/security"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/gtcx-ecosystem/gtcx-core/tree/main/packages/security#readme",
  "bugs": {
    "url": "https://github.com/gtcx-ecosystem/gtcx-core/issues"
  },
  "sideEffects": false
}
