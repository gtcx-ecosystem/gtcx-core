{
  "name": "@gtcx/ai",
  "version": "0.2.1",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@gtcx/tsup-config": "workspace:*",
    "@gtcx/typescript-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtcx-ecosystem/gtcx-core.git",
    "directory": "packages/ai"
  },
  "license": "MIT",
  "homepage": "https://github.com/gtcx-ecosystem/gtcx-core/tree/main/packages/ai#readme",
  "bugs": {
    "url": "https://github.com/gtcx-ecosystem/gtcx-core/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false
}
