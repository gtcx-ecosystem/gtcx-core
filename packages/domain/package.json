{
  "name": "@gtcx/domain",
  "version": "1.0.0",
  "description": "Commodity-agnostic domain services for GTCX Protocol - 10/10 architectural compliance",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.mjs",
      "require": "./dist/schemas.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.mjs",
      "require": "./dist/events.js"
    },
    "./ai-logging": {
      "types": "./dist/ai-logging.d.ts",
      "import": "./dist/ai-logging.mjs",
      "require": "./dist/ai-logging.js"
    },
    "./ai-integration": {
      "types": "./dist/ai-integration.d.ts",
      "import": "./dist/ai-integration.mjs",
      "require": "./dist/ai-integration.js"
    },
    "./metrics": {
      "types": "./dist/metrics.d.ts",
      "import": "./dist/metrics.mjs",
      "require": "./dist/metrics.js"
    },
    "./migrations": {
      "types": "./dist/migrations.d.ts",
      "import": "./dist/migrations.mjs",
      "require": "./dist/migrations.js"
    },
    "./versioning": {
      "types": "./dist/versioning.d.ts",
      "import": "./dist/versioning.mjs",
      "require": "./dist/versioning.js"
    },
    "./offline": {
      "types": "./dist/internal/offline-queue.d.ts",
      "import": "./dist/internal/offline-queue.mjs",
      "require": "./dist/internal/offline-queue.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@gtcx/types": "workspace:*",
    "@gtcx/crypto": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@gtcx/types": {
      "optional": true
    },
    "@gtcx/crypto": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  },
  "keywords": [
    "gtcx",
    "domain",
    "trading",
    "compliance",
    "registration",
    "commodity",
    "gold",
    "verification",
    "offline-first",
    "ai-native"
  ],
  "author": "GTCX Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtcx/gtcx.git",
    "directory": "packages/domain"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
