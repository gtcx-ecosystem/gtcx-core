{
  "name": "@gtcx/domain",
  "version": "3.1.4",
  "description": "Commodity-agnostic domain services for GTCX Protocol - 10/10 architectural compliance",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.mjs",
      "require": "./dist/schemas.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.mjs",
      "require": "./dist/events.js"
    },
    "./ai-logging": {
      "types": "./dist/ai-logging.d.ts",
      "import": "./dist/ai-logging.mjs",
      "require": "./dist/ai-logging.js"
    },
    "./ai-integration": {
      "types": "./dist/ai-integration.d.ts",
      "import": "./dist/ai-integration.mjs",
      "require": "./dist/ai-integration.js"
    },
    "./metrics": {
      "types": "./dist/metrics.d.ts",
      "import": "./dist/metrics.mjs",
      "require": "./dist/metrics.js"
    },
    "./migrations": {
      "types": "./dist/migrations.d.ts",
      "import": "./dist/migrations.mjs",
      "require": "./dist/migrations.js"
    },
    "./versioning": {
      "types": "./dist/versioning.d.ts",
      "import": "./dist/versioning.mjs",
      "require": "./dist/versioning.js"
    },
    "./offline": {
      "types": "./dist/internal/offline-queue.d.ts",
      "import": "./dist/internal/offline-queue.mjs",
      "require": "./dist/internal/offline-queue.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gtcx/events": "workspace:*",
    "@gtcx/utils": "workspace:*",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@gtcx/tsup-config": "workspace:*",
    "@gtcx/typescript-config": "workspace:*",
    "tsup": "^8.0.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  },
  "keywords": [
    "gtcx",
    "domain",
    "trading",
    "compliance",
    "registration",
    "commodity",
    "verification",
    "offline-first",
    "ai-native"
  ],
  "author": "GTCX Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtcx-ecosystem/gtcx-core.git",
    "directory": "packages/domain"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "homepage": "https://github.com/gtcx-ecosystem/gtcx-core/tree/main/packages/domain#readme",
  "bugs": {
    "url": "https://github.com/gtcx-ecosystem/gtcx-core/issues"
  },
  "sideEffects": false
}
