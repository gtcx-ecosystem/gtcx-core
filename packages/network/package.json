{
  "name": "@gtcx/network",
  "version": "0.1.1",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@gtcx/tsup-config": "workspace:*",
    "@gtcx/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.0.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^16.1.5",
    "@chainsafe/libp2p-quic": "^1.1.8",
    "@chainsafe/libp2p-yamux": "^7.0.4",
    "@libp2p/bootstrap": "^11.0.47",
    "@libp2p/identify": "^3.0.39",
    "@libp2p/mdns": "^11.0.47",
    "@libp2p/tcp": "^10.1.19",
    "@multiformats/multiaddr": "^12.5.1",
    "libp2p": "^2.10.0"
  },
  "peerDependenciesMeta": {
    "libp2p": {
      "optional": true
    },
    "@chainsafe/libp2p-quic": {
      "optional": true
    },
    "@chainsafe/libp2p-noise": {
      "optional": true
    },
    "@chainsafe/libp2p-gossipsub": {
      "optional": true
    },
    "@chainsafe/libp2p-yamux": {
      "optional": true
    },
    "@libp2p/bootstrap": {
      "optional": true
    },
    "@libp2p/identify": {
      "optional": true
    },
    "@libp2p/mdns": {
      "optional": true
    },
    "@libp2p/tcp": {
      "optional": true
    },
    "@multiformats/multiaddr": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gtcx-ecosystem/gtcx-core.git",
    "directory": "packages/network"
  },
  "license": "MIT",
  "homepage": "https://github.com/gtcx-ecosystem/gtcx-core/tree/main/packages/network#readme",
  "bugs": {
    "url": "https://github.com/gtcx-ecosystem/gtcx-core/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false
}
