{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "03-platform/packages/types",
    "03-platform/packages/crypto",
    "03-platform/packages/identity",
    "03-platform/packages/verification",
    "03-platform/packages/domain",
    "03-platform/packages/schemas",
    "03-platform/packages/security",
    "03-platform/packages/ai",
    "03-platform/packages/services",
    "03-platform/packages/sync",
    "03-platform/packages/api-client",
    "03-platform/packages/connectivity",
    "03-platform/packages/events",
    "03-platform/packages/utils",
    "03-platform/packages/logging"
  ],
  "out": "00-archive/artifacts/api-docs",
  "plugin": ["typedoc-plugin-markdown"],
  "name": "GTCX Core API Reference",
  "readme": "none",
  "treatWarningsAsErrors": false,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": false
  }
}
