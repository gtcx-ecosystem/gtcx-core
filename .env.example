# gtcx-core environment variables
# Copy to .env and modify as needed

# Node environment
NODE_ENV=development

# Native crypto bindings — set to true in production to enforce Rust-backed crypto
# When true, throws if @gtcx/crypto-native binary is unavailable (no JS fallback)
GTCX_REQUIRE_NATIVE=false

# FIPS 140-2/3 compliance mode — restricts to FIPS-approved algorithms only
# When true: Secp256k1 ECDSA instead of Ed25519, SHA-256/512 only (no Blake3)
GTCX_FIPS_MODE=false

# Custom path to native crypto binary (optional — auto-detected by default)
# GTCX_CRYPTO_NATIVE_PATH=/path/to/gtcx_node.node

# Connectivity probe health endpoint (optional — defaults to https://connectivity.gtcx.io/health)
# GTCX_HEALTH_URL=https://your-api.example.com/health

# mTLS client certificates (for @gtcx/api-client with mTLS enabled)
# MTLS_CERT=/path/to/client.crt
# MTLS_KEY=/path/to/client.key
# MTLS_CA=/path/to/ca.crt
