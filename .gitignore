# Dependencies
node_modules/
.pnpm-store/

# Auth tokens
.npmrc

# Build outputs
dist/
build/
*.tsbuildinfo
docs/api/
rust/target/
*.node

# Compiled output in source directories (should never be committed)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Compiled output in test directories
packages/*/tests/**/*.js
packages/*/tests/**/*.js.map
packages/*/tests/**/*.d.ts
packages/*/tests/**/*.d.ts.map

# Compiled config files (vitest, tsup etc.)
packages/*/vitest.config.js
packages/*/vitest.config.js.map
packages/*/vitest.config.d.ts
packages/*/vitest.config.d.ts.map
packages/*/tsup.config.js
packages/*/tsup.config.js.map
packages/*/tsup.config.d.ts
packages/*/tsup.config.d.ts.map

# Root-level compiled config files
vitest.workspace.js
vitest.workspace.js.map
vitest.workspace.d.ts
vitest.workspace.d.ts.map

# Coverage
coverage/
.nyc_output/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Turbo
.turbo/

# Generated runtime artifacts
artifacts/
quality/api-surface-report.json
benchmarks/performance-report.json
packages/crypto-native/native/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Local archive (historical reference, preserved in git history)
_archive/

# BaselineOS runtime state
.baseline/
